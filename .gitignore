# Ephemeral agent pipeline workspaces
/workspaces

# OS junk
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Python (knowledge-graph)
**/__pycache__/
*.pyc
knowledge-graph/.venv/
knowledge-graph/.server.pid
knowledge-graph/server.log

# Build artifacts — installer binary compiled at the repo root via `go build ./cmd/install`.
# Match only the root-level binary (leading slash); do NOT match the `cmd/install/` source dir.
/install
/install.exe

# User-local tool manager config (mise/asdf) — not project state
mise.toml
.mise.toml

# Phase-4 TS hook build artifacts — node_modules stays untracked; dist/ is
# committed (the CC plugin distributes the git tree with no build step).
hooks/ts/node_modules/

# opencode test suites (test_opencode_session_enforcement.sh, test_opencode_config_resolver.sh)
# compile scratch CJS bundles of *.opencode.ts entries straight into dist/ for their own
# in-process Node execution. Those entries ship as raw TS to the opencode runtime (never
# bundled by `npm run build`), so the scratch bundles are test-local, not distributed.
hooks/ts/dist/*.opencode.cjs
hooks/ts/dist/opencode-plugin.cjs
