{
  "_comment": "Copy the 'hooks' section for your OS into ~/.claude/settings.json. Default is the 'ultra-quiet' preset: notifications fire ONLY on idle_prompt (Claude is waiting for your input), plus a PreToolUse policy gate that blocks destructive commands and writes to sensitive files. The older 'permission_prompt' and 'PostToolUseFailure *' triggers were removed because they fire while work continues — they accumulate in the Windows Action Center / system tray and produce noise without requiring user action. For louder presets (notify on every Stop, on permission_prompt, etc.) see the 'Tuning presets' section of hooks/README.md.",

  "windows": {
    "_requires": "powershell.exe (included in Windows) + python3 (in PATH)",
    "_scripts": "notify-windows.sh, policy-block.sh, checkpoint-guard.sh, dev-guard.sh, gcp-guard.sh, session-start.sh, language-user-prompt.sh",
    "_events": "SessionStart + UserPromptSubmit + PreToolUse (policy-block: Bash|Write|Edit|NotebookEdit; dev-guard: Bash + ClickUp MCP writes; gcp-guard: Bash; checkpoint-guard: Task) + Notification (idle_prompt only)",
    "hooks": {
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/language-user-prompt.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "SessionStart": [
        {
          "matcher": "startup|resume|clear",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/session-start.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "PreToolUse": [
        {
          "matcher": "Bash|Write|Edit|NotebookEdit",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/policy-block.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/dev-guard.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/gcp-guard.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Task",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/checkpoint-guard.sh",
              "timeout": 10
            }
          ]
        },
        {
          "matcher": "mcp__.*__clickup_(update_task|create_task|create_task_comment|attach_task_file)",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/dev-guard.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ]
    }
  },

