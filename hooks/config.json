{
  "_comment": "Copy the 'hooks' section for your OS into ~/.claude/settings.json. Default is the 'ultra-quiet' preset: notifications fire ONLY on idle_prompt (Claude is waiting for your input), plus a PreToolUse policy gate that blocks destructive commands and writes to sensitive files. The older 'permission_prompt' and 'PostToolUseFailure *' triggers were removed because they fire while work continues — they accumulate in the Windows Action Center / system tray and produce noise without requiring user action. For louder presets (notify on every Stop, on permission_prompt, etc.) see the 'Tuning presets' section of hooks/README.md.",
  "_ts_hooks": "Phase 4 (opencode-ts-hooks): TS .cjs entries added as dual-redundancy secondary hooks alongside existing Bash hooks. Bash hooks remain primary (listed first; legacy tests check first entry). TS entries fire second and apply the same logic independently. SessionStart remains session-start.sh (single-entry constraint). Node is already a CC runtime dependency — no new end-user dependency.",

  "windows": {
    "_requires": "node (included with Claude Code)",
    "_scripts": "hooks/policy-block.sh, hooks/dev-guard.sh, hooks/gcp-guard.sh, hooks/worktree-guard.sh, hooks/checkpoint-guard.sh, hooks/prepublish-guard.sh, hooks/subagent-trace.sh, hooks/precompact-snapshot.sh, hooks/_hook-profile.sh (sourced by Bash hooks), hooks/notify-windows.sh (notification only), hooks/notify-stage.sh (orchestrator-invoked)",
    "_scripts_ts": "hooks/ts/dist/policy-block.cjs, hooks/ts/dist/dev-guard.cjs, hooks/ts/dist/gcp-guard.cjs, hooks/ts/dist/worktree-guard.cjs, hooks/ts/dist/prepublish-guard.cjs, hooks/ts/dist/checkpoint-guard.cjs, hooks/ts/dist/subagent-trace.cjs, hooks/ts/dist/precompact-snapshot.cjs (dual-redundancy; added as secondary entries alongside Bash primaries)",
    "_events": "SessionStart + UserPromptSubmit + PreToolUse (policy-block: Bash|Write|Edit|NotebookEdit; dev-guard: Bash + ClickUp MCP writes; gcp-guard: Bash; worktree-guard: Bash; prepublish-guard: Bash; checkpoint-guard: Task) + Notification (idle_prompt only) + SubagentStop (th:.* → subagent-trace) + PreCompact (manual|auto → precompact-snapshot)",
    "hooks": {
      "UserPromptSubmit": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/language-user-prompt.sh",
              "timeout": 5
            }
          ]
        },
        {
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/language-user-prompt.cjs",
              "timeout": 5
            }
          ]
        }
      ],
      "SessionStart": [
        {
          "matcher": "startup|resume|clear",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/session-start.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "PreToolUse": [
        {
          "matcher": "Bash|Write|Edit|NotebookEdit",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/policy-block.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash|Write|Edit|NotebookEdit",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/policy-block.cjs",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/dev-guard.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/dev-guard.cjs",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/gcp-guard.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/gcp-guard.cjs",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/worktree-guard.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/worktree-guard.cjs",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/prepublish-guard.sh",
              "timeout": 120
            }
          ]
        },
        {
          "matcher": "Bash",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/prepublish-guard.cjs",
              "timeout": 120
            }
          ]
        },
        {
          "matcher": "Task",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/checkpoint-guard.sh",
              "timeout": 10
            }
          ]
        },
        {
          "matcher": "Task",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/checkpoint-guard.cjs",
              "timeout": 10
            }
          ]
        },
        {
          "matcher": "mcp__.*__clickup_(update_task|create_task|create_task_comment|attach_task_file)",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/dev-guard.cjs",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "SubagentStop": [
        {
          "matcher": "th:.*",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/subagent-trace.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "th:.*",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/subagent-trace.cjs",
              "timeout": 5
            }
          ]
        }
      ],
      "PreCompact": [
        {
          "matcher": "manual|auto",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/precompact-snapshot.sh",
              "timeout": 5
            }
          ]
        },
        {
          "matcher": "manual|auto",
          "hooks": [
            {
              "type": "command",
              "command": "node ~/.claude/hooks/ts/dist/precompact-snapshot.cjs",
              "timeout": 5
            }
          ]
        }
      ]
    }
  },

