{
  "_comment": "Copy the 'hooks' section for your OS into ~/.claude/settings.json. Default is quiet: notifications fire only when Claude needs your input or a tool fails. Plus a PreToolUse policy gate that blocks destructive commands and writes to sensitive files. To also be notified when Claude finishes a turn, see the opt-in 'Stop' snippet in hooks/README.md.",

  "windows": {
    "_requires": "powershell.exe (included in Windows) + python3 (in PATH)",
    "_scripts": "notify-windows.sh, policy-block.sh",
    "_events": "PreToolUse + Notification + PostToolUseFailure",
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash|Write|Edit|NotebookEdit",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/policy-block.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt|permission_prompt",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "PostToolUseFailure": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-windows.sh",
              "timeout": 5
            }
          ]
        }
      ]
    }
  },

  "macos": {
    "_requires": "osascript (included in macOS) + python3",
    "_scripts": "notify-mac.sh, policy-block.sh",
    "_events": "PreToolUse + Notification + PostToolUseFailure",
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash|Write|Edit|NotebookEdit",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/policy-block.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "Notification": [
        {
          "matcher": "idle_prompt|permission_prompt",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-mac.sh",
              "timeout": 5
            }
          ]
        }
      ],
      "PostToolUseFailure": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-mac.sh",
              "timeout": 5
            }
          ]
        }
      ]
    }
  },

  "linux": {
    "_requires": "libnotify (notify-send) + python3",
    "_scripts": "notify-linux.sh, policy-block.sh",
    "_events": "PreToolUse + Notification + PostToolUseFailure",
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Bash|Write|Edit|NotebookEdit",
