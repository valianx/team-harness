              "timeout": 5
            }
          ]
        }
      ],
      "PostToolUseFailure": [
        {
          "matcher": "*",
          "hooks": [
            {
              "type": "command",
              "command": "bash ~/.claude/hooks/notify-linux.sh",
              "timeout": 5
            }
          ]
        }
      ]
    }
  }
}
