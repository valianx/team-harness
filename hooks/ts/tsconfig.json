{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": [
    "shim/**/*.ts",
    "bodies/**/*.ts",
    "entry/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
