{
  "_comment": "Plugin-mode hooks (loaded by Claude Code plugin runtime). Uses ${CLAUDE_PLUGIN_ROOT} — a plugin runtime variable that resolves to the plugin's install cache directory. Phase 4 (opencode-ts-hooks): TS .cjs entries added as dual-redundancy secondary hooks alongside existing Bash hooks. Bash hooks remain primary (listed first). SessionStart remains session-start.sh (single-entry constraint). Node is already a CC runtime dependency — no new end-user dependency. policy gate (PreToolUse Bash|Write|Edit|NotebookEdit): Bash policy-block.sh primary + TS policy-block.cjs secondary. outward-action gate (PreToolUse Bash): dev-guard.sh primary + dev-guard.cjs secondary. gcp gate (PreToolUse Bash): gcp-guard.sh primary + gcp-guard.cjs secondary. worktree advisory (PreToolUse Bash): worktree-guard.sh primary + worktree-guard.cjs secondary (fail-open). prepublish gate (PreToolUse Bash, 120s): prepublish-guard.sh primary + prepublish-guard.cjs secondary. reasoning-checkpoint (PreToolUse Task): checkpoint-guard.sh primary + checkpoint-guard.cjs secondary (fail-open). ClickUp MCP (PreToolUse mcp__.*__clickup_...): dev-guard.cjs only. Notification: idle_prompt only (Bash notify scripts). SubagentStop (th:.*): subagent-trace.sh primary + subagent-trace.cjs secondary. PreCompact (manual|auto): precompact-snapshot.sh primary + precompact-snapshot.cjs secondary. TH_HOOK_PROFILE controls pipeline-observability class.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/language-user-prompt.sh",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/language-user-prompt.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/policy-block.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/policy-block.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/dev-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/dev-guard.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/gcp-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/gcp-guard.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/worktree-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/worktree-guard.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/prepublish-guard.sh",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/prepublish-guard.cjs",
            "timeout": 120
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/checkpoint-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/checkpoint-guard.cjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__.*__clickup_(update_task|create_task|create_task_comment|attach_task_file)",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/dev-guard.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/notify-stage.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "th:.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/subagent-trace.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "th:.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/subagent-trace.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/precompact-snapshot.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/ts/dist/precompact-snapshot.cjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
